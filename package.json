{
  "name": "nebula-launcher",
  "version": "3.5.0",
  "description": "Nebula - лаунчер для Minecraft-збірок",
  "main": "src/main/main.js",
  "author": "mushbarry",
  "homepage": "https://github.com/mushraisin/Nebula",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^5.4.0",
    "adm-zip": "^0.5.16",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.2"
  },
  "build": {
    "appId": "com.nebula.launcher",
    "productName": "Nebula",
    "copyright": "Copyright © 2026 mushbarry",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "artifactName": "Nebula-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "mushraisin",
        "repo": "Nebula"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Nebula"
    }
  }
}
